---
import "../styles/global.css";
import { SITE, NAV, withBase } from "../lib/site";

interface Props {
  title?: string;
  description?: string;
  ogType?: string;
  jsonLd?: Record<string, unknown> | null;
  noindex?: boolean;
}
const {
  title,
  description = SITE.description,
  ogType = "website",
  jsonLd = null,
  noindex = false,
} = Astro.props;

const pageTitle = title ? `${title} — ${SITE.name}` : SITE.title;
const canonical = new URL(Astro.url.pathname, Astro.site).href;
const ogImage = new URL(withBase("/og.png"), Astro.site).href;
const here = Astro.url.pathname.replace(/\/$/, "") || "/";
const isCurrent = (href: string) => {
  const h = withBase(href).replace(/\/$/, "") || "/";
  return h === "/" ? here === "/" : here === h || here.startsWith(h + "/");
};
const year = new Date().getFullYear();
const updated = new Date().toISOString().slice(0, 10);
---
<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{pageTitle}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <meta name="robots" content={noindex ? "noindex, nofollow" : "index, follow"} />

    <meta property="og:type" content={ogType} />
    <meta property="og:site_name" content={SITE.name} />
    <meta property="og:title" content={pageTitle} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content={ogImage} />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={pageTitle} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content={ogImage} />

    <meta name="theme-color" content="#1f4ed8" />
    <link rel="icon" href={withBase("/favicon.svg")} type="image/svg+xml" />
    <link rel="sitemap" href={withBase("/sitemap-index.xml")} />
    <link
      rel="alternate"
      type="application/rss+xml"
      title={`${SITE.name} — Writing`}
      href={withBase("/rss.xml")}
    />
    {jsonLd && (
      <script type="application/ld+json" set:html={JSON.stringify(jsonLd)} />
    )}
  </head>
  <body>
    <a class="skip" href="#main">Skip to content</a>
    <header class="site-head">
      <div class="wrap">
        <a class="brand" href={withBase("/")}>{SITE.name}</a>
        <nav class="nav" aria-label="Primary">
          {NAV.map((item) => (
            <a
              href={withBase(item.href)}
              aria-current={isCurrent(item.href) ? "page" : undefined}
            >
              {item.label}
            </a>
          ))}
        </nav>
      </div>
    </header>

    <main id="main">
      <div class="wrap">
        <slot />
      </div>
    </main>

    <footer class="site-foot">
      <div class="wrap">
        <div>© {year} {SITE.name}</div>
        <div class="links">
          <a href={`mailto:${SITE.email}`}>Email</a>
          {Object.entries(SITE.profiles).map(([label, url]) => (
            <a href={url} rel="me noopener" target="_blank">{label}</a>
          ))}
        </div>
        <div class="small">Last updated {updated}</div>
      </div>
    </footer>
  </body>
</html>
