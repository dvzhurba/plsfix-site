---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/site";
import { getCollection } from "astro:content";

const ts = (v?: string) => {
  const t = new Date(String(v ?? "")).getTime();
  return isNaN(t) ? 0 : t;
};
const fmtDate = (v?: string) => {
  if (!v) return "";
  const dt = new Date(v);
  return isNaN(dt.getTime())
    ? String(v)
    : dt.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
};
const items = (await getCollection("writing"))
  .filter((w) => !w.data.unlisted)
  .sort((a, b) => ts(b.data.date) - ts(a.data.date));
const real = (h?: string) => typeof h === "string" && /^https?:\/\//.test(h);
---
<Base title="Writing" description="Articles and analysis by Denis Zhurba.">
  <h1>Writing</h1>
  <p class="muted">Self-hosted pieces and stubs for externally published work, so everything is discoverable from one place.</p>
  <ul class="itemlist">
    {items.map((a) => (
      <li>
        <div class="row">
          <a class="t" href={withBase(`/writing/${a.id}`)}>{a.data.title}</a>
          <span class="d">
            {a.data.status === "draft" ? "Draft" : (real(a.data.external_url) ? a.data.publication : fmtDate(a.data.date))}
          </span>
        </div>
        {a.data.summary && <div class="note">{a.data.summary}</div>}
      </li>
    ))}
  </ul>
</Base>
