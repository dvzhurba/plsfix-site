---
import Base from "../layouts/Base.astro";
import { SITE, withBase } from "../lib/site";
import { getEntry } from "astro:content";

const home = await getEntry("pages", "home");
const data: any = home?.data ?? {};

const selected = (
  await Promise.all(
    (data.selected_writing ?? []).map((slug: string) => getEntry("writing", slug)),
  )
).filter(Boolean) as any[];

const person = {
  "@context": "https://schema.org",
  "@type": "Person",
  name: SITE.name,
  jobTitle: "AI/ML Product Leader",
  url: new URL(withBase("/"), Astro.site).href,
  description: SITE.description,
  sameAs: Object.values(SITE.profiles),
};
---
<Base jsonLd={person}>
  <section class="hero">
    <h1>{data.name ?? SITE.name}</h1>
    {data.hook && (
      <p class="hook" set:html={data.hook.replaceAll("→", '<span class="arr">→</span>')} />
    )}
  </section>

  {data.identity && (
    <dl class="identity">
      {data.identity.map((row: any) => (
        <div class="idrow">
          <dt>{row.label}</dt>
          <dd set:html={row.html} />
        </div>
      ))}
    </dl>
  )}

  {selected.length > 0 && (
    <section>
      <div class="section-label">Stuff I've written</div>
      <ul class="itemlist">
        {selected.map((a) => (
          <li>
            <div class="row">
              <a class="t" href={withBase(`/writing/${a.id}`)}>{a.data.title}</a>
              <span class="d">{a.data.publication}</span>
            </div>
            {a.data.summary && <div class="note">{a.data.summary}</div>}
          </li>
        ))}
      </ul>
      <p class="small"><a href={withBase("/writing")}>All writing →</a></p>
    </section>
  )}

  {data.play && (
    <section>
      <div class="section-label">Play with it</div>
      <ul class="cards play">
        {data.play.map((p: any) => (
          <li class="card">
            <h3><a class="title" href={withBase(p.href)}>{p.title} →</a></h3>
            <p>{p.desc}</p>
          </li>
        ))}
      </ul>
    </section>
  )}

  {(data.about || data.ctas) && (
    <section class="closing">
      {data.about && <p class="aboutline">{data.about}</p>}
      {data.ctas && (
        <div class="ctas">
          {data.ctas.map((c: any) => (
            <a
              class={"btn" + (String(c.label).toLowerCase() === "cv" ? " secondary" : "")}
              href={withBase(c.href)}
            >{c.label}</a>
          ))}
        </div>
      )}
    </section>
  )}
</Base>
