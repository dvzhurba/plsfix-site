---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/site";
import { getCollection, render } from "astro:content";

export async function getStaticPaths() {
  const items = await getCollection("work");
  return items.map((item) => ({ params: { slug: item.id }, props: { item } }));
}

const { item } = Astro.props;
const d: any = item.data;
const { Content } = await render(item);
const real = (h?: string) => typeof h === "string" && /^https?:\/\//.test(h);
---
<Base title={d.title} description={d.summary}>
  <p class="small"><a href={withBase("/work")}>← Work</a></p>
  <h1>{d.title}</h1>
  <p class="muted">{d.role}{d.role && d.dates ? " · " : ""}{d.dates}</p>
  {d.outcome && <p class="lead">{d.outcome}</p>}
  <article class="prose">
    <Content />
  </article>
  {Array.isArray(d.links) && d.links.length > 0 && (
    <>
      <div class="section-label">Links</div>
      <ul>
        {d.links.map((l: any) => (
          <li>
            <a href={real(l.href) ? l.href : withBase(l.href)} {...(real(l.href) ? { target: "_blank", rel: "noopener" } : {})}>{l.label}</a>
          </li>
        ))}
      </ul>
    </>
  )}
  {Array.isArray(d.tags) && d.tags.length > 0 && (
    <ul class="tags">{d.tags.map((t: string) => <li>{t}</li>)}</ul>
  )}
</Base>
