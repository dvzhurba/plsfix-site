---
import Base from "../../layouts/Base.astro";
import { getCollection } from "astro:content";

const items = (await getCollection("talks")).sort((a, b) =>
  String(b.data.date ?? "").localeCompare(String(a.data.date ?? "")),
);
const real = (h?: string) => typeof h === "string" && /^https?:\/\//.test(h);
---
<Base title="Talks" description="Talks, lectures, panels, and judging by Denis Zhurba.">
  <h1>Talks &amp; lectures</h1>
  <ul class="itemlist">
    {items.map((t) => (
      <li>
        <div class="row">
          <span class="t">
            {real(t.data.url) ? <a href={t.data.url} target="_blank" rel="noopener">{t.data.title}</a> : t.data.title}
          </span>
          <span class="d">{[t.data.venue, t.data.date].filter((x) => x && !/todo/i.test(String(x))).join(" · ")}</span>
        </div>
        {t.data.note && <div class="note">{t.data.note}</div>}
      </li>
    ))}
  </ul>
</Base>
