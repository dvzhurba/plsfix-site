---
import Base from "../../layouts/Base.astro";
import { withBase } from "../../lib/site";
import { getCollection } from "astro:content";

const ts = (v?: string) => { const t = new Date(String(v ?? "")).getTime(); return isNaN(t) ? 0 : t; };
const fmtDate = (v?: any) => {
  if (!v || /todo/i.test(String(v))) return "";
  const dt = new Date(v);
  return isNaN(dt.getTime()) ? String(v) : dt.toLocaleDateString("en-GB", { day: "numeric", month: "short", year: "numeric" });
};
const items = (await getCollection("recognition"))
  .filter((r) => !r.data.unlisted)
  .sort((a, b) => ts(b.data.date) - ts(a.data.date));
---
<Base title="Recognition" description="Awards, judging, mentoring, and press for Denis Zhurba.">
  <h1>Recognition</h1>
  <p class="muted">Awards, mentoring, judging, and press — each linking to a verifiable source.</p>
  <ul class="itemlist">
    {items.map((r) => (
      <li>
        <div class="row">
          <a class="t" href={withBase(`/recognition/${r.id}`)}>{r.data.title}</a>
          <span class="d">{[r.data.venue, fmtDate(r.data.date)].filter((x) => x && !/todo/i.test(String(x))).join(" · ")}</span>
        </div>
        {r.data.note && <div class="note">{r.data.note}</div>}
      </li>
    ))}
  </ul>
</Base>
